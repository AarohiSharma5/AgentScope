# Frontend build-time configuration (Vite). Copy to `.env` and adjust as needed.
# Only variables prefixed with VITE_ are exposed to the client bundle.

# Base URL for the REST API and the SSE stream. Defaults to the same-origin
# "/api" path (served via the Vite dev proxy and a production reverse proxy).
# Set this for split deployments where the API lives on a different origin.
# VITE_API_BASE_URL=https://api.example.com/api

# Optional static API key used instead of an interactive login (sent as the
# X-API-Key header). Leave unset to use the normal email/password session flow.
# VITE_API_KEY=
