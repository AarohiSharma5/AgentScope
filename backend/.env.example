# Environment: "development" (default) or "production".
# In production the app refuses to boot unless AUTH_ENABLED=true and strong,
# non-default SECRET_KEY / JWT_SECRET are set.
AGENTSCOPE_ENV=development

# Secrets — generate strong random values for any non-local deployment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
# JWT_SECRET=change-me-in-production   # defaults to SECRET_KEY if unset

# Authentication: enforce auth on all data routes. Required in production.
AUTH_ENABLED=false

# Persist ApiKey.last_used_at at most once per this many seconds per key, to
# avoid an UPDATE-per-request write storm on a hot key under ingest traffic.
# Set 0 to write on every request (exact, but contended).
# API_KEY_LAST_USED_DEBOUNCE_SECONDS=60

# Database
# For PostgreSQL (recommended):
#   DATABASE_URL=postgresql://user:password@localhost:5432/agentscope
# If unset, the app falls back to a local SQLite file for easy dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentscope

# CORS - comma separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173

# Model prices (USD per 1K tokens) for accurate cost estimates — extends/overrides
# the built-in table so your own/self-hosted/fine-tuned models are priced too.
# Inline JSON or a path to a JSON file. A bare number is an input-only price.
# Unknown models record NO cost (shown as "unpriced"), never a wrong $0.
# AGENTSCOPE_MODEL_PRICES={"my-model": [0.002, 0.004], "llama3.2": [0, 0]}
# AGENTSCOPE_MODEL_PRICES=/etc/agentscope/prices.json

# Server-side PII/secret redaction at ingest (defense-in-depth for raw-HTTP
# clients that bypass the SDK's own redaction). Off by default. When on,
# prompt/response/tool/document text is scrubbed before it is stored.
# AGENTSCOPE_INGEST_REDACT=false
# Extend the built-in patterns (email, API keys, cards, SSN, phone, IP):
# AGENTSCOPE_INGEST_REDACT_PATTERNS=[["ACME-\\d+", "[ACCOUNT]"]]

# Concurrency / connection pool (PostgreSQL only; SQLite ignores pool sizing).
# DB_POOL_SIZE + DB_MAX_OVERFLOW is the hard ceiling on concurrent DB connections
# per process. Workflow parallel branches each may hold one connection, so keep
# WORKFLOW_MAX_PARALLELISM x (concurrent workflows) below that ceiling.
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# WORKFLOW_MAX_PARALLELISM=8
