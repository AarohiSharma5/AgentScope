# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database
# For PostgreSQL (recommended):
#   DATABASE_URL=postgresql://user:password@localhost:5432/agentscope
# If unset, the app falls back to a local SQLite file for easy dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentscope

# CORS - comma separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173
